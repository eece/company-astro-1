---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { statsData, testimonials, partnerBrands } from '../data';

// Fetch all services from the Content Collection
const allServices = await getCollection('hizmetler');
// Take first 3 for featured display
const featuredServices = allServices.slice(0, 3);

const base = import.meta.env.BASE_URL;
const iletisimUrl = `${base}iletisim`;
const hizmetlerimizUrl = `${base}hizmetlerimiz`;
---

<Layout title="Yaratıcı Web & Dijital Mühendislik Ajansı">
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden py-20 bg-gradient-to-b from-white to-neutral-50" id="hero">
    <!-- Grid overlay for tech look -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e5e5e5_1px,transparent_1px),linear-gradient(to_bottom,#e5e5e5_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30"></div>
    
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 w-full">
      <!-- Text Area -->
      <div class="lg:col-span-7 flex flex-col items-start gap-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-50 border border-emerald-200 text-emerald-700 font-mono text-xs font-semibold uppercase tracking-wider animate-pulse">
          <Icon name="Sparkles" size={14} class="text-emerald-500" />
          Yarının Teknolojisi, Bugün Yayında
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 tracking-tight leading-[1.1]">
          Dijital Varlığınızı <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500 relative">
            Roket Hızına
          </span> Ulaştırın.
        </h1>

        <p class="text-lg text-neutral-600 leading-relaxed max-w-xl">
          Geleneksel ve hantal kurumsal şablonlardan uzaklaşın. Astra Digital ile modern, ultra hızlı (Lighthouse 95+), erişilebilir ve SEO odaklı dijital çözümler üretiyoruz.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto">
          <a
            href={iletisimUrl}
            class="flex items-center justify-center gap-2 bg-neutral-900 hover:bg-emerald-600 text-white font-sans text-base font-semibold px-8 py-4 rounded-full transition-all duration-300 group shadow-lg hover:shadow-emerald-500/10 cursor-pointer"
          >
            Projenizi Başlatın
            <Icon name="ArrowRight" size={18} class="group-hover:translate-x-1 transition-transform" />
          </a>
          <a
            href={hizmetlerimizUrl}
            class="flex items-center justify-center gap-2 bg-white hover:bg-neutral-100 border border-neutral-200 text-neutral-800 font-sans text-base font-semibold px-8 py-4 rounded-full transition-all duration-300 cursor-pointer"
          >
            Hizmetlerimizi İnceleyin
          </a>
        </div>
      </div>

      <!-- Graphical Illustration (CSS Visual Card) -->
      <div class="lg:col-span-5 relative hidden lg:block">
        <!-- Floating shapes & patterns -->
        <div class="absolute -top-10 -left-10 w-40 h-40 bg-emerald-300 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-teal-300 rounded-full blur-3xl opacity-20"></div>
        
        <div class="bg-white border border-neutral-100 rounded-3xl p-8 shadow-2xl shadow-neutral-200/50 relative z-10">
          <!-- Window controls -->
          <div class="flex items-center gap-1.5 mb-6">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
          </div>

          <div class="flex flex-col gap-5">
            <!-- Tech Card 1 -->
            <div class="bg-neutral-50 rounded-2xl p-4 border border-neutral-100 flex items-center gap-4 hover:scale-102 transition-transform duration-300">
              <div class="w-12 h-12 rounded-xl bg-emerald-500 flex items-center justify-center text-white">
                <Icon name="Cpu" size={24} />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-bold text-neutral-800">Ultra-Hızlı Kod</span>
                <span class="text-xs text-neutral-500">SSG & Ada Mimarisi ile roket hızı</span>
              </div>
              <span class="ml-auto font-mono text-emerald-600 font-bold text-sm bg-emerald-50 px-2 py-1 rounded">100ms</span>
            </div>

            <!-- Tech Card 2 -->
            <div class="bg-neutral-50 rounded-2xl p-4 border border-neutral-100 flex items-center gap-4 hover:scale-102 transition-transform duration-300">
              <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-600">
                <Icon name="TrendingUp" size={24} />
              </div>
              <div class="flex flex-col">
                <span class="font-display font-bold text-neutral-800">Kusursuz SEO</span>
                <span class="text-xs text-neutral-500">Arama motorlarında en üst sıralar</span>
              </div>
              <span class="ml-auto font-mono text-emerald-600 font-bold text-sm bg-emerald-50 px-2 py-1 rounded">Score 100</span>
            </div>

            <!-- Decorative chart representation -->
            <div class="bg-neutral-900 text-white rounded-2xl p-5 mt-2 flex flex-col gap-3 shadow-lg shadow-neutral-950/10">
              <div class="flex justify-between items-center">
                <span class="text-sm font-semibold tracking-wide uppercase font-mono text-neutral-400">Performans Analitiği</span>
                <div class="flex gap-1">
                  <span class="w-1.5 h-3 bg-emerald-500 rounded-full"></span>
                  <span class="w-1.5 h-5 bg-emerald-400 rounded-full animate-bounce"></span>
                  <span class="w-1.5 h-4 bg-emerald-500 rounded-full"></span>
                </div>
              </div>
              <div class="h-20 flex items-end gap-3 pt-4 border-b border-neutral-800 pb-2">
                <div class="bg-neutral-800 w-full h-[40%] rounded-t-md hover:bg-emerald-500 transition-colors cursor-pointer"></div>
                <div class="bg-neutral-800 w-full h-[65%] rounded-t-md hover:bg-emerald-500 transition-colors cursor-pointer"></div>
                <div class="bg-neutral-800 w-full h-[55%] rounded-t-md hover:bg-emerald-500 transition-colors cursor-pointer"></div>
                <div class="bg-emerald-500 w-full h-[95%] rounded-t-md"></div>
              </div>
              <span class="text-[10px] font-mono text-neutral-400">Hız testi tamamlandı. Sonuç: Harika</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats & Values Section -->
  <section class="py-24 bg-white border-y border-neutral-100" id="stats">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center mb-16">
        <div class="lg:col-span-5">
          <h2 class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest mb-3">Değerlerimiz & Etkimiz</h2>
          <p class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight leading-tight">
            Performansı Raporlarla Değil, Sonuçlarla Kanıtlıyoruz.
          </p>
        </div>
        <div class="lg:col-span-7">
          <p class="text-neutral-600 leading-relaxed text-lg">
            Astra Digital, teknolojiyi sadece kullanmakla kalmaz; işinizin hedeflerine uyacak şekilde hassas bir mühendislikle tasarlar. Her satır kodu performans, sürdürülebilirlik ve maksimum dönüşüm odaklı yazıyoruz.
          </p>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {statsData.map((stat, idx) => (
          <div class="bg-neutral-50 rounded-3xl p-8 border border-neutral-100 hover:shadow-xl hover:shadow-neutral-200/40 transition-all duration-300 flex flex-col gap-4 relative group overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-neutral-200 group-hover:bg-emerald-500 transition-colors"></div>
            <div class="font-display font-extrabold text-5xl text-neutral-900 tracking-tight group-hover:text-emerald-600 transition-colors">
              {stat.value}
            </div>
            <div class="flex flex-col gap-1">
              <span class="font-display font-bold text-neutral-800 text-lg leading-snug">{stat.label}</span>
              <span class="text-sm text-neutral-500 leading-relaxed">{stat.description}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Services Section -->
  <section class="py-24 bg-neutral-50" id="featured-services">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6 mb-16">
        <div>
          <span class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest block mb-3">Öne Çıkan Çözümler</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight">İşinizi Geleceğe Taşıyacak Hizmetler</h2>
        </div>
        <a
          href={hizmetlerimizUrl}
          class="inline-flex items-center gap-2 bg-white hover:bg-neutral-900 hover:text-white border border-neutral-200 text-neutral-800 font-sans text-sm font-semibold px-6 py-3 rounded-full transition-all duration-300 shadow-sm cursor-pointer"
        >
          Tüm Hizmetleri Gör
          <Icon name="ArrowRight" size={16} />
        </a>
      </div>

      <!-- Services List -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        {featuredServices.map((service) => (
          <div class="bg-white border border-neutral-100 rounded-3xl p-8 shadow-sm hover:shadow-2xl hover:shadow-neutral-200/60 transition-all duration-300 flex flex-col gap-6 group relative overflow-hidden">
            <div class="w-12 h-12 rounded-2xl bg-emerald-50 group-hover:bg-emerald-500 flex items-center justify-center text-emerald-600 group-hover:text-white transition-all duration-300">
              <Icon name={service.data.iconName} size={24} />
            </div>

            <div class="flex flex-col gap-2">
              <span class="text-xs font-mono font-bold uppercase tracking-wider text-neutral-400">{service.data.category}</span>
              <h3 class="font-display font-bold text-xl text-neutral-900 group-hover:text-emerald-600 transition-colors">{service.data.title}</h3>
              <p class="text-sm text-neutral-600 leading-relaxed mt-1">{service.data.shortDescription}</p>
            </div>

            <div class="mt-auto pt-6 border-t border-neutral-50 flex items-center">
              <a href={`${base}hizmetlerimiz/${service.id}`} class="text-sm font-semibold text-neutral-800 hover:text-emerald-600 inline-flex items-center gap-1.5 transition-colors group/link cursor-pointer">
                Detayları İncele
                <Icon name="ArrowRight" size={16} class="group-hover/link:translate-x-1 transition-transform" />
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials & Brand Logos -->
  <section class="py-24 bg-white border-t border-neutral-100 overflow-hidden" id="social-proof">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest block mb-3">Müşteri Yorumları</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight">İş Ortaklarımızın Astra Hakkındaki Görüşleri</h2>
      </div>

      <!-- Testimonials Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20">
        {testimonials.map((test) => (
          <div class="bg-neutral-50 border border-neutral-100 rounded-3xl p-8 flex flex-col gap-6 shadow-sm hover:shadow-lg transition-shadow">
            <!-- Stars -->
            <div class="flex gap-1 text-amber-500">
              {Array.from({ length: test.rating }).map(() => (
                <Icon name="Star" size={16} class="fill-current" />
              ))}
            </div>

            <p class="text-sm leading-relaxed text-neutral-600 italic">
              "{test.text}"
            </p>

            <!-- User Info -->
            <div class="flex items-center gap-4 mt-auto pt-6 border-t border-neutral-100">
              <img
                src={test.image}
                alt={test.name}
                class="w-12 h-12 rounded-full object-cover border-2 border-white shadow-md"
                loading="lazy"
              />
              <div class="flex flex-col">
                <span class="font-display font-bold text-sm text-neutral-900">{test.name}</span>
                <span class="text-xs text-neutral-500">{test.role}, {test.company}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Brands Belt -->
      <div class="border-t border-neutral-100 pt-16 text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-neutral-400 mb-8">BİRLİKTE BÜYÜDÜĞÜMÜZ PRESTİJLİ MARKALAR</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 opacity-60 grayscale hover:opacity-100 transition-opacity duration-300">
          {partnerBrands.map((brand) => (
            <div class="flex items-center gap-2 font-display font-semibold text-lg text-neutral-700">
              <span class="text-2xl">{brand.logo}</span>
              <span>{brand.name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Conversion CTA Banner -->
  <section class="py-20 bg-neutral-950 text-white relative overflow-hidden" id="conversion-cta">
    <div class="absolute inset-0 bg-emerald-950/20 mix-blend-color"></div>
    <!-- Graphical circle background -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-emerald-500/10 rounded-full blur-3xl opacity-30 pointer-events-none"></div>
    
    <div class="max-w-5xl mx-auto px-6 text-center relative z-10 flex flex-col items-center gap-8">
      <span class="font-mono text-emerald-400 text-xs font-bold uppercase tracking-widest">Sıradaki Başarı Hikayesi Sizinki Olsun</span>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        Fikrinizi Sektör Lideri Bir Dijital Ürüne Dönüştürelim
      </h2>
      <p class="text-neutral-400 max-w-xl leading-relaxed text-base sm:text-lg">
        Gereksinimlerinizi konuşmak, teknolojik altyapı önerisi ve fiyat teklifi almak için bizimle hemen iletişime geçin. Ekibimiz en geç 24 saat içinde dönüş yapacaktır.
      </p>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 w-full sm:w-auto">
        <a
          href={iletisimUrl}
          class="flex items-center justify-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-neutral-950 font-sans font-bold text-base px-8 py-4 rounded-full transition-all duration-300 group cursor-pointer"
        >
          Hemen İletişime Geçin
          <Icon name="ArrowRight" size={18} class="group-hover:translate-x-1 transition-transform text-neutral-950" />
        </a>
      </div>
    </div>
  </section>
</Layout>
