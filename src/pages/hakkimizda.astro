---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { teamMembers, milestones } from '../data';
---

<Layout title="Hakkımızda & Ekibimiz">
  <!-- Page Header -->
  <section class="py-20 bg-neutral-900 text-white relative overflow-hidden" id="about-header">
    <div class="absolute inset-0 bg-gradient-to-r from-emerald-950/20 to-neutral-950/40"></div>
    <!-- Mesh-like pattern overlay -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#334155_1px,transparent_1px),linear-gradient(to_bottom,#334155_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-10"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10 text-center flex flex-col items-center gap-6">
      <span class="font-mono text-emerald-400 text-xs font-bold uppercase tracking-widest">KİMİZ BİZ?</span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white leading-tight">
        Geleceği Kodlayan <br />Yenilikçi Mühendislik Kadrosu
      </h1>
      <p class="text-neutral-400 text-lg sm:text-xl max-w-2xl leading-relaxed">
        Standart kalıpların dışına çıkıyoruz. Tasarımda sadeliğe, mühendislikte ise hız ve yüksek performansa inanıyoruz.
      </p>
    </div>
  </section>

  <!-- Story & Vision-Mission (Asymmetric Grid) -->
  <section class="py-24 bg-white" id="story-vision">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <!-- Story Text -->
        <div class="lg:col-span-6 flex flex-col gap-6">
          <span class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest">HİKAYEMİZ</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight leading-snug">
            3 Kişilik Küçük Bir Ofisten, Sınırları Aşan Dijital Güce...
          </h2>
          <p class="text-neutral-600 leading-relaxed text-base">
            Astra Digital, 2018 yılında hantal web siteleri ve karmaşık altyapılar sebebiyle iş kaybeden markalara yardımcı olmak amacıyla kuruldu. Amacımız basitti: İnterneti daha hızlı, daha temiz ve kullanıcılar için daha konforlu bir yer haline getirmek.
          </p>
          <p class="text-neutral-600 leading-relaxed text-base">
            Bugün gelinen noktada, Türkiye'de ve yurt dışındaki onlarca prestijli markaya modern web mühendisliği, özel yapay zeka otomasyonları ve göz alıcı tasarımlar sunarak onların büyüme hikayelerine liderlik ediyoruz. Bizim için her proje, yeni bir hız ve kullanıcı deneyimi rekoru kırma şansıdır.
          </p>
        </div>

        <!-- Vision/Mission Cards (Asymmetric look) -->
        <div class="lg:col-span-6 grid grid-cols-1 sm:grid-cols-2 gap-8">
          <!-- Card 1: Vizyon -->
          <div class="bg-neutral-50 rounded-3xl p-8 border border-neutral-100 flex flex-col gap-4 shadow-sm hover:shadow-lg transition-all duration-300 transform sm:-translate-y-4">
            <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
              <Icon name="Target" size={24} />
            </div>
            <h3 class="font-display font-bold text-xl text-neutral-900">Vizyonumuz</h3>
            <p class="text-sm text-neutral-600 leading-relaxed">
              Milisaniyelerle yarışan modern dijital dünyada, işletmelerin arama motorlarında ve mobil cihazlarda zirvede yer almasını sağlayacak en kararlı, optimize ve sürdürülebilir altyapıları standart hale getirmek.
            </p>
          </div>

          <!-- Card 2: Misyon -->
          <div class="bg-neutral-50 rounded-3xl p-8 border border-neutral-100 flex flex-col gap-4 shadow-sm hover:shadow-lg transition-all duration-300 transform sm:translate-y-4">
            <div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
              <Icon name="Award" size={24} />
            </div>
            <h3 class="font-display font-bold text-xl text-neutral-900">Misyonumuz</h3>
            <p class="text-sm text-neutral-600 leading-relaxed">
              İşletmelerin ihtiyaçlarını tam olarak analiz edip, gereksiz şişirilmiş kod yığınlarından ve şablonlardan kaçınarak, onlara özel, özgün, yüksek dönüşüm sağlayan kullanıcı dostu dijital ürünler geliştirmek.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline / Milestones (Chronological Infographic) -->
  <section class="py-24 bg-neutral-50 border-y border-neutral-100" id="milestones">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest block mb-3">YOLCULUĞUMUZ</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight">Gelişim ve Başarı Dolu Kilometre Taşlarımız</h2>
      </div>

      <!-- Vertical Timeline Layout -->
      <div class="relative border-l border-neutral-200 ml-4 md:ml-32 py-4 flex flex-col gap-12">
        {milestones.map((ms) => (
          <div class="relative pl-8 md:pl-12 group">
            <!-- Year Badge (Floating left on wider screens) -->
            <div class="hidden md:flex absolute right-full mr-12 top-1 font-display font-black text-3xl text-neutral-300 group-hover:text-emerald-500 transition-colors">
              {ms.year}
            </div>

            <!-- Bullet point on the timeline line -->
            <div class="absolute -left-1.5 top-2 w-3 h-3 rounded-full bg-neutral-300 group-hover:bg-emerald-500 group-hover:scale-125 transition-all duration-300 border border-white"></div>

            <div class="bg-white rounded-2xl p-6 border border-neutral-100 shadow-sm group-hover:shadow-md transition-shadow">
              <!-- Year for mobile only -->
              <span class="md:hidden inline-block px-2.5 py-1 rounded bg-emerald-50 text-emerald-700 font-mono text-xs font-bold mb-3">{ms.year}</span>
              <h3 class="font-display font-bold text-lg text-neutral-900 group-hover:text-emerald-600 transition-colors mb-2">
                {ms.title}
              </h3>
              <p class="text-neutral-600 text-sm leading-relaxed">
                {ms.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team Members Section -->
  <section class="py-24 bg-white" id="team">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-20">
        <span class="font-display text-xs font-semibold text-emerald-600 uppercase tracking-widest block mb-3">EKİBİMİZ</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-neutral-900 tracking-tight">Kreatif Zihinler & Mühendislik Dehaları</h2>
        <p class="text-neutral-500 mt-4 text-sm sm:text-base">
          Müşterilerimizin dijital rüyalarını hayata geçiren, heyecanlı ve üretken Astra kadrosunu yakından tanıyın.
        </p>
      </div>

      <!-- Team Members Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {teamMembers.map((member) => (
          <div class="group bg-neutral-50 rounded-3xl p-6 border border-neutral-100 hover:shadow-2xl hover:shadow-neutral-200/50 transition-all duration-300 flex flex-col items-center text-center">
            <!-- Rounded avatar with unique borders -->
            <div class="relative w-40 h-40 mb-6 overflow-hidden rounded-full border-4 border-white shadow-lg group-hover:border-emerald-500 transition-all duration-300">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>

            <!-- Role / Details -->
            <div class="flex flex-col gap-1 mb-3">
              <h3 class="font-display font-bold text-lg text-neutral-900 group-hover:text-emerald-600 transition-colors">{member.name}</h3>
              <span class="text-xs font-mono font-bold uppercase tracking-wider text-neutral-400">{member.role}</span>
            </div>

            <p class="text-sm leading-relaxed text-neutral-600 mb-6 px-2">
              {member.bio}
            </p>

            <!-- Social Links inside team card -->
            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-neutral-100 w-full justify-center">
              {member.social.linkedin && (
                <a href={member.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-emerald-500 transition-colors" aria-label={`${member.name} LinkedIn`}>
                  <Icon name="Linkedin" size={16} />
                </a>
              )}
              {member.social.github && (
                <a href={member.social.github} target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-emerald-500 transition-colors" aria-label={`${member.name} GitHub`}>
                  <Icon name="Github" size={16} />
                </a>
              )}
              {member.social.twitter && (
                <a href={member.social.twitter} target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-emerald-500 transition-colors" aria-label={`${member.name} Twitter`}>
                  <Icon name="Twitter" size={16} />
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
