---
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../index.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Astra Digital | Yüksek Performanslı, Modern ve Yenilikçi Kurumsal Dijital Çözümler sunan web ajansı.",
  image,
} = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <style>
      /* Ensure proper smooth scroll offsets for fixed navbar anchor clicks */
      html {
        scroll-padding-top: 100px;
      }
    </style>
  </head>
  <body class="bg-neutral-50 text-neutral-900 selection:bg-emerald-500 selection:text-white">
    <!-- Navbar -->
    <Navbar />

    <!-- Main Content Stage -->
    <main class="pt-[88px] min-h-[calc(100vh-88px)] flex flex-col">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />
  </body>
</html>
